    TweenService:Create(DupeBtn, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(255, 40, 120)}):Play()
end)

DupeBtn.MouseButton1Click:Connect(function()
    if not selectedRealItemName then
        StatusText.Text = "❌ Select a REAL item first (not fake)"
        StatusText.TextColor3 = Color3.fromRGB(255, 70, 70)
        wait(1.5)
        StatusText.Text = "Select a REAL item"
        StatusText.TextColor3 = Color3.fromRGB(170, 170, 190)
        return
    end
    
    StatusText.Text = "🔮 Creating FAKE copy of " .. selectedRealItemName .. " in backpack..."
    StatusText.TextColor3 = Color3.fromRGB(255, 200, 50)
    
    TweenService:Create(DupeBtn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(180, 0, 200)}):Play()
    
    wait(0.3)
    
    -- Add fake item to local list
    local fakeName = selectedRealItemName .. "_copy_" .. tostring(#fakeItems + 1)
    table.insert(fakeItems, selectedRealItemName)
    
    -- Visual flash effect
    local flash = Instance.new("Frame")
    flash.Size = UDim2.new(1, 0, 1, 0)
    flash.BackgroundColor3 = Color3.fromRGB(0, 255, 150)
    flash.BackgroundTransparency = 0.5
    flash.Parent = MainFrame
    TweenService:Create(flash, TweenInfo.new(0.3), {BackgroundTransparency = 1}):Play()
    game:GetService("Debris"):AddItem(flash, 0.3)
    
    updateDisplay()
    
    -- Find the newly added fake button and animate it
    wait(0.05)
    for _, btn in pairs(itemButtons) do
        if btn.Text:find(selectedRealItemName) and btn.Text:find("COPY") then
            local origColor = btn.BackgroundColor3
            TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(0, 200, 100)}):Play()
            wait(0.2)
            TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = origColor}):Play()
            break
        end
    end
    
    StatusText.Text = "✅ FAKE item added to BACKPACK (visual only!)"
    StatusText.TextColor3 = Color3.fromRGB(0, 255, 100)
    TweenService:Create(DupeBtn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(255, 40, 120)}):Play()
    
    wait(2.5)
    StatusText.Text = "Select a REAL item"
    StatusText.TextColor3 = Color3.fromRGB(170, 170, 190)
end)

-- Update when real items change
LocalPlayer.CharacterAdded:Connect(function(newChar)
    Character = newChar
    updateDisplay()
end)

