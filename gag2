-- LocalScript: визуальный клиентский дубликат предмета в руке (виден только тебе)

local Players = game:GetService("Players")
local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

-- ===== Создаём GUI с кнопкой =====
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "DupeGui"
screenGui.ResetOnSpawn = false
screenGui.Parent = playerGui

local button = Instance.new("TextButton")
button.Size = UDim2.new(0, 160, 0, 50)
button.Position = UDim2.new(0, 20, 0.5, -25)
button.BackgroundColor3 = Color3.fromRGB(45, 45, 55)
button.TextColor3 = Color3.fromRGB(255, 255, 255)
button.Font = Enum.Font.GothamBold
button.TextSize = 16
button.Text = "Дублировать"
button.Parent = screenGui

local clearButton = Instance.new("TextButton")
clearButton.Size = UDim2.new(0, 160, 0, 40)
clearButton.Position = UDim2.new(0, 20, 0.5, 30)
clearButton.BackgroundColor3 = Color3.fromRGB(80, 40, 40)
clearButton.TextColor3 = Color3.fromRGB(255, 255, 255)
clearButton.Font = Enum.Font.Gotham
clearButton.TextSize = 14
clearButton.Text = "Убрать клоны"
clearButton.Parent = screenGui

-- ===== Логика =====
local clones = {}      -- список созданных клонов
local connections = {} -- связи RenderStepped для слежения

local RunService = game:GetService("RunService")

local function getEquippedTool()
	local char = player.Character
	if not char then return nil end
	return char:FindFirstChildOfClass("Tool")
end

local function duplicate()
	local tool = getEquippedTool()
	if not tool then
		warn("В руке нет предмета (Tool)")
		return
	end

	local handle = tool:FindFirstChild("Handle")
	if not handle then
		warn("У предмета нет Handle")
		return
	end

	-- Клонируем визуальную часть
	local clone = handle:Clone()
	-- Убираем скрипты/звуки, оставляем только визуал
	for _, d in ipairs(clone:GetDescendants()) do
		if d:IsA("Script") or d:IsA("LocalScript") or d:IsA("Sound") then
			d:Destroy()
		end
	end
	clone.Anchored = true
	clone.CanCollide = false
	clone.CanTouch = false
	clone.Transparency = math.min(handle.Transparency + 0.2, 0.6) -- чуть прозрачнее, чтобы отличать
	clone.Parent = workspace -- только на клиенте => виден только тебе

	-- Смещение от оригинала, чтобы клон было видно рядом
	local offset = CFrame.new(0, 3, 0)

	-- Привязываем клон к движению руки
	local conn = RunService.RenderStepped:Connect(function()
		if not handle or not handle.Parent then return end
		clone.CFrame = handle.CFrame * offset
	end)

	table.insert(clones, clone)
	table.insert(connections, conn)
end

local function clearClones()
	for _, conn in ipairs(connections) do
		if conn.Connected then conn:Disconnect() end
	end
	for _, c in ipairs(clones) do
		if c and c.Parent then c:Destroy() end
	end
	clones = {}
	connections = {}
end

button.MouseButton1Click:Connect(duplicate)
clearButton.MouseButton1Click:Connect(clearClones)
