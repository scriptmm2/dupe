-- FLY SYSTEM
local function startFly()
    if flyEnabled then return end
    flyEnabled = true
    local char = GetPlayerChar()
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    bodyVelocity = Instance.new("BodyVelocity")
    bodyVelocity.MaxForce = Vector3.new(10000, 10000, 10000)
    bodyVelocity.Velocity = Vector3.new(0, 0, 0)
    bodyVelocity.Parent = hrp
    
    local flying = true
    local flySpeed = currentFlySpeed
    
    local wKey, aKey, sKey, dKey, spaceKey = false, false, false, false, false
    
    local con1 = UIS.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        local key = input.KeyCode
        if key == Enum.KeyCode.W then wKey = true
        elseif key == Enum.KeyCode.A then aKey = true
        elseif key == Enum.KeyCode.S then sKey = true
        elseif key == Enum.KeyCode.D then dKey = true
        elseif key == Enum.KeyCode.Space then spaceKey = true
        end
    end)
    
    local con2 = UIS.InputEnded:Connect(function(input, gameProcessed)
        local key = input.KeyCode
        if key == Enum.KeyCode.W then wKey = false
        elseif key == Enum.KeyCode.A then aKey = false
        elseif key == Enum.KeyCode.S then sKey = false
        elseif key == Enum.KeyCode.D then dKey = false
        elseif key == Enum.KeyCode.Space then spaceKey = false
        end
    end)
    
    while flyEnabled and hrp and hrp.Parent do
        local cam = workspace.CurrentCamera
        local forward = cam.CFrame.LookVector
        local right = cam.CFrame.RightVector
        local up = Vector3.new(0, 1, 0)
        
        local velocity = Vector3.new(0, 0, 0)
        if wKey then velocity = velocity + forward
        elseif sKey then velocity = velocity - forward end
        if dKey then velocity = velocity + right
        elseif aKey then velocity = velocity - right end
        if spaceKey then velocity = velocity + up end
        
        if velocity.Magnitude > 0 then
            velocity = velocity.Unit * flySpeed
        end
        
        if bodyVelocity then
            bodyVelocity.Velocity = velocity
        end
        
        wait()
    end
    
    con1:Disconnect()
    con2:Disconnect()
    if bodyVelocity then bodyVelocity:Destroy() end
end

local function stopFly()
    flyEnabled = false
    if bodyVelocity then
        bodyVelocity:Destroy()
        bodyVelocity = nil
    end
end

