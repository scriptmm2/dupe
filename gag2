-- ОБХОД БЛОКИРОВКИ CoreGui
local StarterGui = game:GetService("StarterGui")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local RS = game:GetService("ReplicatedStorage")

-- ПЕРЕМЕННЫЕ
local autoSell = false
local autoHarvest = false  
local autoPlant = false
local autoAura = false
local speedHack = false
local jumpHack = false
local speedValue = 50
local jumpValue = 120

-- УВЕДОМЛЕНИЕ (РАБОТАЕТ ВСЕГДА)
local function Notify(text)
    pcall(function()
        StarterGui:SetCore("SendNotification", {
            Title = "🌿 RYZEN",
            Text = text,
            Duration = 2
        })
    end)
    print("[RYZEN] " .. text)
end

-- ОСНОВНОЙ ЦИКЛ ФАРМА
spawn(function()
    while wait(0.2) do
        if autoHarvest or autoSell then
            local plots = workspace:FindFirstChild("Plots")
            if plots then
                for _, plot in pairs(plots:GetChildren()) do
                    if autoHarvest and plot:GetAttribute("IsReady") then
                        pcall(function() RS:FindFirstChild("HarvestPlant"):FireServer(plot) end)
                    end
                    if autoSell and plot:FindFirstChild("Fruit") then
                        pcall(function() RS:FindFirstChild("SellItem"):FireServer(plot.Fruit) end)
                    end
                end
            end
        end
        
        if autoPlant then
            local plots = workspace:FindFirstChild("Plots")
            if plots then
                for _, plot in pairs(plots:GetChildren()) do
                    if plot:GetAttribute("IsEmpty") then
                        pcall(function() RS:FindFirstChild("PlantSeed"):FireServer(plot) end)
                        wait(0.1)
                    end
                end
            end
        end
        
        if autoAura then
            local auras = workspace:FindFirstChild("AuraParts")
            if auras then
                for _, aura in pairs(auras:GetChildren()) do
                    pcall(function() RS:FindFirstChild("CollectAura"):FireServer(aura) end)
                end
            end
        end
    end
end)

-- SPEED + JUMP
spawn(function()
    while wait(0.3) do
        local char = LocalPlayer.Character
        local hum = char and char:FindFirstChild("Humanoid")
        if hum then
            if speedHack then hum.WalkSpeed = speedValue end
            if jumpHack then hum.JumpPower = jumpValue end
        end
    end
end)

-- ████████████ СОЗДАНИЕ GUI (ПРОСТОЙ И РАБОЧИЙ) ████████████

local screenGui = Instance.new("ScreenGui")
screenGui.Name = "RyzenGUI"
screenGui.ResetOnSpawn = false

-- ПЫТАЕМСЯ ПРИЦЕПИТЬ GUI В РАЗНЫЕ МЕСТА
local success = false
local parentOptions = {game.CoreGui, game:GetService("Players").LocalPlayer.PlayerGui, game:GetService("GuiService")}

for _, parent in pairs(parentOptions) do
    if parent and not success then
        pcall(function()
            screenGui.Parent = parent
            success = true
        end)
    end
end

if not success then
    -- ПОСЛЕДНЯЯ ПОПЫТКА - СОЗДАЕМ ЧЕРЕЗ КОМАНДНУЮ СТРОКУ
    loadstring([[
        local notification = Instance.new("ScreenGui")
        notification.Parent = game.CoreGui
        local frame = Instance.new("Frame", notification)
        frame.Size = UDim2.new(0, 300, 0, 100)
        frame.Position = UDim2.new(0.5, -150, 0.5, -50)
        frame.BackgroundColor3 = Color3.fromRGB(0,0,0)
        local text = Instance.new("TextLabel", frame)
        text.Size = UDim2.new(1,0,1,0)
        text.Text = "RYZEN: /ryzen в чате"
        text.TextColor3 = Color3.fromRGB(0,255,0)
        text.TextScaled = true
        game:GetService("Debris"):AddItem(notification, 3)
    ]])()
end

-- ГЛАВНОЕ ОКНО (ЕСЛИ GUI СОЗДАЛСЯ)
if success then
    local mainFrame = Instance.new("Frame")
    mainFrame.Size = UDim2.new(0, 320, 0, 450)
    mainFrame.Position = UDim2.new(0.5, -160, 0.5, -225)
    mainFrame.BackgroundColor3 = Color3.fromRGB(25, 25, 40)
    mainFrame.BackgroundTransparency = 0.1
    mainFrame.Parent = screenGui
    Instance.new("UICorner", mainFrame).CornerRadius = UDim.new(0, 12)
    
    -- ЗАГОЛОВОК
    local title = Instance.new("TextLabel")
    title.Size = UDim2.new(1, 0, 0, 45)
    title.BackgroundColor3 = Color3.fromRGB(0, 180, 80)
    title.Text = "🌿 RYZEN GARDEN"
    title.TextColor3 = Color3.fromRGB(255, 255, 255)
    title.TextScaled = true
    title.Font = Enum.Font.GothamBold
    title.Parent = mainFrame
    Instance.new("UICorner", title).CornerRadius = UDim.new(0, 12)
    
    -- СКРОЛЛ ФРЕЙМ
    local scroll = Instance.new("ScrollingFrame")
    scroll.Size = UDim2.new(1, -10, 1, -55)
    scroll.Position = UDim2.new(0, 5, 0, 50)
    scroll.BackgroundTransparency = 1
    scroll.CanvasSize = UDim2.new(0, 0, 0, 350)
    scroll.ScrollBarThickness = 3
    scroll.Parent = mainFrame
    
    local layout = Instance.new("UIListLayout", scroll)
    layout.Padding = UDim.new(0, 6)
    
    -- ФУНКЦИЯ СОЗДАНИЯ КНОПОК-ТОГГЛОВ
    local function addToggle(text, varRef, color)
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(0.95, 0, 0, 50)
        btn.BackgroundColor3 = color or Color3.fromRGB(60, 60, 90)
        btn.Text = text .. " ❌"
        btn.TextColor3 = Color3.fromRGB(255, 255, 255)
        btn.TextScaled = true
        btn.Font = Enum.Font.Gotham
        btn.Parent = scroll
        Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)
        
        local active = false
        btn.MouseButton1Click:Connect(function()
            active = not active
            _G[varRef] = active
            btn.Text = text .. (active and " ✅" or " ❌")
            btn.BackgroundColor3 = active and Color3.fromRGB(0, 150, 70) or (color or Color3.fromRGB(60, 60, 90))
            Notify(text, active and "Включено" or "Выключено")
        end)
    end
    
    -- ФУНКЦИЯ ДЛЯ СЛАЙДЕРОВ
    local function addSlider(text, varRef, minVal, maxVal, defVal)
        local frame = Instance.new("Frame")
        frame.Size = UDim2.new(0.95, 0, 0, 65)
        frame.BackgroundColor3 = Color3.fromRGB(40, 40, 60)
        frame.Parent = scroll
        Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 8)
        
        local label = Instance.new("TextLabel")
        label.Size = UDim2.new(1, -10, 0, 25)
        label.Position = UDim2.new(0, 5, 0, 5)
        label.BackgroundTransparency = 1
        label.Text = text .. ": " .. defVal
        label.TextColor3 = Color3.fromRGB(255, 255, 255)
        label.TextSize = 13
        label.Parent = frame
        
        local slider = Instance.new("TextBox")
        slider.Size = UDim2.new(0.6, 0, 0, 30)
        slider.Position = UDim2.new(0.2, 0, 0, 30)
        slider.BackgroundColor3 = Color3.fromRGB(70, 70, 100)
        slider.Text = tostring(defVal)
        slider.TextColor3 = Color3.fromRGB(255, 255, 255)
        slider.Parent = frame
        Instance.new("UICorner", slider).CornerRadius = UDim.new(0, 6)
        
        slider.FocusLost:Connect(function()
            local val = tonumber(slider.Text)
            if val then
                val = math.clamp(val, minVal, maxVal)
                _G[varRef] = val
                slider.Text = tostring(val)
                label.Text = text .. ": " .. val
            else
                slider.Text = tostring(_G[varRef] or defVal)
            end
        end)
    end
    
    -- ██████ СОЗДАЕМ КНОПКИ ██████
    addToggle("💰 АВТО-ПРОДАЖА", "autoSell", Color3.fromRGB(180, 70, 70))
    addToggle("🌽 АВТО-СБОР", "autoHarvest", Color3.fromRGB(70, 180, 70))
    addToggle("🌱 АВТО-ПОСАДКА", "autoPlant", Color3.fromRGB(70, 130, 200))
    addToggle("✨ АВТО-АВРА", "autoAura", Color3.fromRGB(170, 70, 200))
    addToggle("🏃 SPEED HACK", "speedHack", Color3.fromRGB(200, 150, 50))
    addToggle("🦘 JUMP HACK", "jumpHack", Color3.fromRGB(200, 150, 50))
    
    addSlider("⚡ СКОРОСТЬ", "speedValue", 16, 300, 50)
    addSlider("🦘 ПРЫЖОК", "jumpValue", 50, 300, 120)
    
    -- КНОПКА ЗАКРЫТИЯ
    local closeBtn = Instance.new("TextButton")
    closeBtn.Size = UDim2.new(0, 35, 0, 35)
    closeBtn.Position = UDim2.new(1, -42, 0, 5)
    closeBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
    closeBtn.Text = "✕"
    closeBtn.TextScaled = true
    closeBtn.Parent = mainFrame
    Instance.new("UICorner", closeBtn).CornerRadius = UDim.new(1, 0)
    closeBtn.MouseButton1Click:Connect(function()
        screenGui:Destroy()
        Notify("GUI закрыт. Перезапусти скрипт чтобы открыть снова")
    end)
    
    -- ПЕРЕТАСКИВАНИЕ ДЛЯ ТЕЛЕФОНА
    local drag = false
    local dragStart, startPos
    title.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
            drag = true
            dragStart = input.Position
            startPos = mainFrame.Position
        end
    end)
    title.InputEnded:Connect(function() drag = false end)
    game:GetService("UserInputService").InputChanged:Connect(function(input)
        if drag and (input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseMovement) then
            local delta = input.Position - dragStart
            mainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    
    Notify("GUI ЗАГРУЖЕН! Тащи окно за зеленую полосу")
else
    -- ЕСЛИ GUI НЕ СОЗДАЛСЯ - РАБОТАЕМ БЕЗ НЕГО
    Notify("❌ GUI не создался, но читы работают!")
    Notify("Управление: /farm on /farm off /speed 100 /jump 150")
    
    -- ЧАТ-КОМАНДЫ КАК ЗАПАСНОЙ ВАРИАНТ
    LocalPlayer.Chatted:Connect(function(msg)
        if msg == "/farm on" then
            autoSell = true; autoHarvest = true; autoPlant = true; autoAura = true
            Notify("✅ ВСЕ ФУНКЦИИ ВКЛЮЧЕНЫ")
        elseif msg == "/farm off" then
            autoSell = false; autoHarvest = false; autoPlant = false; autoAura = false
            Notify("❌ ВСЕ ФУНКЦИИ ВЫКЛЮЧЕНЫ")
        elseif msg:match("/speed (.+)$") then
            local val = tonumber(msg:match("/speed (.+)$"))
            if val then speedValue = math.clamp(val, 16, 300); Notify("⚡ Скорость: " .. speedValue) end
        elseif msg:match("/jump (.+)$") then
            local val = tonumber(msg:match("/jump (.+)$"))
            if val then jumpValue = math.clamp(val, 50, 300); Notify("🦘 Прыжок: " .. jumpValue) end
        end
    end)
end

Notify("RYZEN ULTIMATE | Готов к работе!", 3)
print("✅ RYZEN MOBILE FIX LOADED - WORKING ON DELTA")
