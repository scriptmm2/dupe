-- ========================= Logic =========================
local clones = {}
local connections = {}

local function getEquippedTool()
	local char = player.Character
	if not char then return nil end
	return char:FindFirstChildOfClass("Tool")
end

local function duplicate()
	local tool = getEquippedTool()
	if not tool then
		status.Text = "No item equipped"
		return
	end

	local handle = tool:FindFirstChild("Handle")
	if not handle then
		status.Text = "Item has no Handle"
		return
	end

	local clone = handle:Clone()

	-- IMPORTANT: remove anything that links the clone to your body,
	-- otherwise moving the clone drags you into the air.
	for _, d in ipairs(clone:GetDescendants()) do
		if d:IsA("Weld") or d:IsA("WeldConstraint") or d:IsA("Motor6D")
			or d:IsA("Script") or d:IsA("LocalScript") or d:IsA("Sound") then
			d:Destroy()
		end
	end

	clone.Anchored = true
	clone.CanCollide = false
	clone.CanTouch = false
	clone.Massless = true
	clone.Transparency = math.clamp(handle.Transparency + 0.15, 0, 0.6)
	clone.Parent = workspace -- client-only => visible only to you

	local offset = CFrame.new(0, 3, 0)

	local conn = RunService.RenderStepped:Connect(function()
		if not handle or not handle.Parent then return end
		clone.CFrame = handle.CFrame * offset
	end)

	table.insert(clones, clone)
	table.insert(connections, conn)
	status.Text = "Duplicated! Clones: " .. #clones
end

local function clearClones()
	for _, conn in ipairs(connections) do
		if conn.Connected then conn:Disconnect() end
	end
	for _, c in ipairs(clones) do
		if c and c.Parent then c:Destroy() end
	end
	clones = {}
	connections = {}
	status.Text = "Cleared all clones"
end

dupBtn.MouseButton1Click:Connect(duplicate)
clearBtn.MouseButton1Click:Connect(clearClones)
