local selectedItemName = nil
local selectedButton = nil
local itemButtons = {}

local function updateInventoryDisplay()
    for _, btn in pairs(itemButtons) do
        btn:Destroy()
    end
    itemButtons = {}
    
    local items = {}
    for _, item in pairs(Backpack:GetChildren()) do
        if item:IsA("Tool") then
            table.insert(items, item)
        end
    end
    
    local canvasY = 0
    
    for _, item in pairs(items) do
        local itemBtn = Instance.new("TextButton")
        itemBtn.Size = UDim2.new(0.94, 0, 0, 48)
        itemBtn.BackgroundColor3 = Color3.fromRGB(35, 35, 45)
        itemBtn.BackgroundTransparency = 0
        itemBtn.Text = "📦 " .. item.Name
        itemBtn.TextColor3 = Color3.fromRGB(220, 220, 240)
        itemBtn.TextSize = 14
        itemBtn.Font = Enum.Font.GothamSemibold
        itemBtn.TextXAlignment = Enum.TextXAlignment.Left
        itemBtn.Parent = ItemsContainer
        local BtnCorner = Instance.new("UICorner")
        BtnCorner.CornerRadius = UDim.new(0, 8)
        BtnCorner.Parent = itemBtn
        
        local iconFrame = Instance.new("Frame")
        iconFrame.Size = UDim2.new(0, 32, 1, 0)
        iconFrame.BackgroundColor3 = Color3.fromRGB(255, 50, 100)
        iconFrame.BackgroundTransparency = 0.8
        iconFrame.Parent = itemBtn
        local IconCorner = Instance.new("UICorner")
        IconCorner.CornerRadius = UDim.new(0, 8)
        IconCorner.Parent = iconFrame
        
        itemBtn.MouseEnter:Connect(function()
            if selectedButton ~= itemBtn then
                itemBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 65)
            end
        end)
        
        itemBtn.MouseLeave:Connect(function()
            if selectedButton ~= itemBtn then
                itemBtn.BackgroundColor3 = Color3.fromRGB(35, 35, 45)
            end
        end)
        
        itemBtn.MouseButton1Click:Connect(function()
            if selectedButton then
                selectedButton.BackgroundColor3 = Color3.fromRGB(35, 35, 45)
            end
            selectedButton = itemBtn
            selectedItemName = item.Name
            itemBtn.BackgroundColor3 = Color3.fromRGB(100, 30, 150)
            StatusText.Text = "Selected: " .. selectedItemName
            StatusText.TextColor3 = Color3.fromRGB(0, 255, 150)
            
            local tween = TweenService:Create(itemBtn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(120, 40, 170)})
            tween:Play()
        end)
        
        itemButtons[item.Name] = itemBtn
        canvasY = canvasY + 56
    end
    
    ItemsContainer.CanvasSize = UDim2.new(0, 0, 0, math.max(canvasY, 300))
    
    if #items == 0 then
        local emptyLabel = Instance.new("TextLabel")
        emptyLabel.Size = UDim2.new(1, 0, 0, 60)
        emptyLabel.BackgroundTransparency = 1
        emptyLabel.Text = "✨ No items in backpack ✨"
        emptyLabel.TextColor3 = Color3.fromRGB(120, 120, 140)
        emptyLabel.TextSize = 14
        emptyLabel.Font = Enum.Font.Gotham
        emptyLabel.Parent = ItemsContainer
        ItemsContainer.CanvasSize = UDim2.new(0, 0, 0, 100)
    end
end

DupeBtn.MouseEnter:Connect(function()
    TweenService:Create(DupeBtn, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(220, 30, 80)}):Play()
end)

DupeBtn.MouseLeave:Connect(function()
    TweenService:Create(DupeBtn, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(255, 50, 100)}):Play()
end)

DupeBtn.MouseButton1Click:Connect(function()
    if not selectedItemName then
        StatusText.Text = "❌ No item selected!"
        StatusText.TextColor3 = Color3.fromRGB(255, 80, 80)
        TweenService:Create(StatusText, TweenInfo.new(0.2), {TextColor3 = Color3.fromRGB(255, 80, 80)}):Play()
        wait(1.5)
        StatusText.Text = "Select an item to duplicate"
        StatusText.TextColor3 = Color3.fromRGB(160, 160, 180)
        return
    end
    
    local realItem = nil
    for _, item in pairs(Backpack:GetChildren()) do
        if item:IsA("Tool") and item.Name == selectedItemName then
            realItem = item
            break
        end
    end
    
    if not realItem then
        StatusText.Text = "❌ Item not found!"
        return
    end
    
    StatusText.Text = "🔮 Duplicating " .. selectedItemName .. "..."
    StatusText.TextColor3 = Color3.fromRGB(255, 200, 50)
    
    TweenService:Create(DupeBtn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(150, 0, 200)}):Play()
    
    wait(0.3)
    
    local fakeClone = Instance.new("Frame")
    fakeClone.Size = UDim2.new(0.9, 0, 0, 44)
    fakeClone.Position = UDim2.new(0.05, 0, 0.2, 0)
    fakeClone.BackgroundColor3 = Color3.fromRGB(0, 200, 100)
    fakeClone.BackgroundTransparency = 0.2
    fakeClone.BorderSizePixel = 0
    fakeClone.Parent = MainFrame
    local CloneCorner = Instance.new("UICorner")
    CloneCorner.CornerRadius = UDim.new(0, 8)
    CloneCorner.Parent = fakeClone
    
    local cloneText = Instance.new("TextLabel")
    cloneText.Size = UDim2.new(1, 0, 1, 0)
    cloneText.BackgroundTransparency = 1
    cloneText.Text = "+ " .. selectedItemName .. " [VISUAL COPY]"
    cloneText.TextColor3 = Color3.fromRGB(0, 255, 150)
    cloneText.TextSize = 13
    cloneText.Font = Enum.Font.GothamBold
    cloneText.Parent = fakeClone
    
    for i = 1, 25 do
        wait(0.03)
        fakeClone.Position = UDim2.new(0.05, 0, 0.2, i * 3)
        fakeClone.BackgroundTransparency = 0.2 + (i / 25) * 0.8
        cloneText.TextTransparency = (i / 25)
    end
    
    fakeClone:Destroy()
    
    StatusText.Text = "✅ Visual duplicate added! +1 " .. selectedItemName
    StatusText.TextColor3 = Color3.fromRGB(0, 255, 100)
    TweenService:Create(DupeBtn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(255, 50, 100)}):Play()
    
    wait(2)
    StatusText.Text = "Select an item to duplicate"
    StatusText.TextColor3 = Color3.fromRGB(160, 160, 180)
end)

Backpack.ChildAdded:Connect(updateInventoryDisplay)
Backpack.ChildRemoved:Connect(updateInventoryDisplay)

updateInventoryDisplay()

local appearTween = TweenService:Create(MainFrame, TweenInfo.new(0.3, Enum.EasingStyle.Back), {BackgroundTransparency = 0})
