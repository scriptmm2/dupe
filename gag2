-- Получение ВСЕХ реальных предметов из рюкзака (без дублей по имени)
local function getRealItems()
    local names = {}
    for _, child in pairs(Backpack:GetChildren()) do
        -- Берём имя любого объекта, даже если не Tool
        local name = child.Name
        if name and name ~= "" then
            names[name] = true
        end
    end
    local result = {}
    for name in pairs(names) do
        table.insert(result, name)
    end
    table.sort(result)
    return result
end

-- Перерисовать весь список (реальные + фейковые)
local function refreshList()
    -- Очищаем кнопки
    for _, btn in pairs(buttons) do
        btn:Destroy()
    end
    buttons = {}
    
    local realNames = getRealItems()
    local allItems = {}
    for _, name in ipairs(realNames) do
        table.insert(allItems, {name = name, type = "REAL"})
    end
    for _, name in ipairs(fakeItems) do
        table.insert(allItems, {name = name, type = "FAKE"})
    end
    
    local totalHeight = 0
    for _, info in ipairs(allItems) do
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(0.96, 0, 0, 48)
        btn.BackgroundColor3 = (info.type == "FAKE") and Color3.fromRGB(45, 25, 70) or Color3.fromRGB(25, 25, 45)
        btn.BackgroundTransparency = 0
        btn.BorderSizePixel = 0
        btn.Parent = ItemsScroller
        
        local btnCorner = Instance.new("UICorner")
        btnCorner.CornerRadius = UDim.new(0, 8)
        btnCorner.Parent = btn
        
        -- Цветная полоска слева
        local colorBar = Instance.new("Frame")
        colorBar.Size = UDim2.new(0, 38, 1, 0)
        colorBar.BackgroundColor3 = (info.type == "FAKE") and Color3.fromRGB(180, 50, 255) or Color3.fromRGB(0, 200, 150)
        colorBar.BackgroundTransparency = 0.2
        colorBar.Parent = btn
        local barCorner = Instance.new("UICorner")
        barCorner.CornerRadius = UDim.new(0, 8)
        barCorner.Parent = colorBar
        
        local icon = Instance.new("TextLabel")
        icon.Size = UDim2.new(1, 0, 1, 0)
        icon.BackgroundTransparency = 1
        icon.Text = (info.type == "FAKE") and "🟣" or "📦"
        icon.TextColor3 = Color3.fromRGB(255, 255, 255)
        icon.TextSize = 22
        icon.Font = Enum.Font.GothamBold
        icon.Parent = colorBar
        
        local nameLabel = Instance.new("TextLabel")
        nameLabel.Size = UDim2.new(1, -50, 1, 0)
        nameLabel.Position = UDim2.new(0, 46, 0, 0)
        nameLabel.BackgroundTransparency = 1
        nameLabel.Text = info.name .. (info.type == "FAKE" and " [КОПИЯ]" or "")
        nameLabel.TextColor3 = (info.type == "FAKE") and Color3.fromRGB(200, 160, 255) or Color3.fromRGB(255, 255, 255)
        nameLabel.TextSize = 14
        nameLabel.Font = Enum.Font.GothamSemibold
        nameLabel.TextXAlignment = Enum.TextXAlignment.Left
        nameLabel.Parent = btn
        
        local badge = Instance.new("TextLabel")
        badge.Size = UDim2.new(0, 70, 0, 18)
        badge.Position = UDim2.new(1, -80, 0.5, -9)
        badge.BackgroundColor3 = (info.type == "FAKE") and Color3.fromRGB(120, 30, 180) or Color3.fromRGB(0, 120, 100)
        badge.BackgroundTransparency = 0.4
        badge.Text = info.type == "FAKE" and "ФЕЙК" or "РЕАЛ"
        badge.TextColor3 = Color3.fromRGB(255, 255, 255)
        badge.TextSize = 10
        badge.Font = Enum.Font.GothamBold
        badge.Parent = btn
        local badgeCorner = Instance.new("UICorner")
        badgeCorner.CornerRadius = UDim.new(1, 0)
        badgeCorner.Parent = badge
        
        btn.Metadata = info
        
        -- Ховер
        btn.MouseEnter:Connect(function()
            if selectedButton ~= btn then
                TweenService:Create(btn, TweenInfo.new(0.1), {BackgroundColor3 = (info.type == "FAKE") and Color3.fromRGB(65, 40, 95) or Color3.fromRGB(45, 45, 65)}):Play()
            end
        end)
        btn.MouseLeave:Connect(function()
            if selectedButton ~= btn then
                TweenService:Create(btn, TweenInfo.new(0.1), {BackgroundColor3 = (info.type == "FAKE") and Color3.fromRGB(45, 25, 70) or Color3.fromRGB(25, 25, 45)}):Play()
            end
        end)
        
        -- Клик по РЕАЛЬНОМУ предмету
        if info.type == "REAL" then
            btn.MouseButton1Click:Connect(function()
                if selectedButton then
                    TweenService:Create(selectedButton, TweenInfo.new(0.15), {BackgroundColor3 = (selectedButton.Metadata.type == "FAKE") and Color3.fromRGB(45, 25, 70) or Color3.fromRGB(25, 25, 45)}):Play()
                end
                selectedButton = btn
                selectedRealItem = info.name
                TweenService:Create(btn, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(80, 50, 140)}):Play()
                StatusLabel.Text = "✅ Выбран: " .. info.name
                StatusLabel.TextColor3 = Color3.fromRGB(0, 255, 150)
            end)
        else
            -- ПКМ по фейку - удалить
            btn.MouseButton2Click:Connect(function()
                for i, fname in ipairs(fakeItems) do
                    if fname == info.name then
                        table.remove(fakeItems, i)
                        break
                    end
                end
                refreshList()
                CounterLabel.Text = "Фейк: " .. #fakeItems
                StatusLabel.Text = "🗑️ Фейк удалён"
                StatusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
                task.wait(1.2)
                StatusLabel.Text = selectedRealItem and ("Выбран: " .. selectedRealItem) or "Выбери реальный предмет"
                StatusLabel.TextColor3 = selectedRealItem and Color3.fromRGB(0, 255, 150) or Color3.fromRGB(160, 160, 200)
            end)
        end
        
        buttons[btn] = btn
        totalHeight = totalHeight + 56
    end
    
    ItemsScroller.CanvasSize = UDim2.new(0, 0, 0, math.max(totalHeight, 300))
    CounterLabel.Text = "Фейк: " .. #fakeItems
    
    if #allItems == 0 then
        local empty = Instance.new("TextLabel")
        empty.Size = UDim2.new(1, 0, 0, 60)
        empty.BackgroundTransparency = 1
        empty.Text = "💀 Рюкзак пуст\nПоложи туда хоть что-нибудь"
        empty.TextColor3 = Color3.fromRGB(120, 120, 160)
        empty.TextSize = 13
        empty.Font = Enum.Font.Gotham
        empty.TextWrapped = true
        empty.Parent = ItemsScroller
        ItemsScroller.CanvasSize = UDim2.new(0, 0, 0, 100)
    end
end

