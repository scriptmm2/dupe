    StatusLabel.Text = "Выбран: " .. selectedRealItem
    StatusLabel.TextColor3 = Color3.fromRGB(0, 255, 150)
end)

-- Перетаскивание окна
local dragging = false
local dragStartPos, dragStartMouse = nil, nil
TitleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStartPos = MainFrame.Position
        dragStartMouse = input.Position
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStartMouse
        MainFrame.Position = UDim2.new(dragStartPos.X.Scale, dragStartPos.X.Offset + delta.X, dragStartPos.Y.Scale, dragStartPos.Y.Offset + delta.Y)
    end
end)
UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
end)

-- Изменение размера
local resizing = false
local resizeStartSize, resizeStartMouse = nil, nil
ResizeHandle.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        resizing = true
        resizeStartSize = MainFrame.Size
        resizeStartMouse = input.Position
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if resizing and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - resizeStartMouse
        local newW = math.clamp(resizeStartSize.X.Offset + delta.X, 380, 800)
        local newH = math.clamp(resizeStartSize.Y.Offset + delta.Y, 480, 900)
        MainFrame.Size = UDim2.new(0, newW, 0, newH)
        ItemsScroller.Size = UDim2.new(1, -24, 0, newH - 170)
        BottomFrame.Position = UDim2.new(0, 12, 1, -92)
        BottomFrame.Size = UDim2.new(1, -24, 0, 80)
    end
end)
UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then resizing = false end
end)

