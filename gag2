-- Helper: get all display items (real + fake)
local function getAllItems()
    local items = {}
    -- Real from backpack
    for _, tool in pairs(Backpack:GetChildren()) do
        if tool:IsA("Tool") then
            table.insert(items, {name = tool.Name, type = "REAL", source = "Backpack", ref = tool})
        end
    end
    -- Real from character (hands)
    if Character then
        for _, tool in pairs(Character:GetChildren()) do
            if tool:IsA("Tool") then
                table.insert(items, {name = tool.Name, type = "REAL", source = "Hand", ref = tool})
            end
        end
    end
    -- Fake items (visual only)
    for i, fake in ipairs(fakeItems) do
        table.insert(items, {name = fake.name, type = "FAKE", source = "Visual Backpack", id = i})
    end
    return items
end

-- Update the scrolling frame with all items
local function refreshInventory()
    for _, btn in pairs(itemButtons) do
        btn:Destroy()
    end
    itemButtons = {}
    
    local items = getAllItems()
    local canvasHeight = 0
    
    for _, info in ipairs(items) do
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(0.96, 0, 0, 52)
        btn.BackgroundColor3 = (info.type == "FAKE") and Color3.fromRGB(30, 20, 50) or Color3.fromRGB(20, 22, 35)
        btn.BackgroundTransparency = 0
        btn.BorderSizePixel = 0
        btn.Parent = ItemsContainer
        
        local btnCorner = Instance.new("UICorner")
        btnCorner.CornerRadius = UDim.new(0, 8)
        btnCorner.Parent = btn
        
        -- Icon
        local icon = Instance.new("Frame")
        icon.Size = UDim2.new(0, 40, 1, 0)
        icon.BackgroundColor3 = (info.type == "FAKE") and Color3.fromRGB(180, 50, 255) or Color3.fromRGB(0, 200, 150)
        icon.BackgroundTransparency = 0.2
        icon.Parent = btn
        local iconCorner = Instance.new("UICorner")
        iconCorner.CornerRadius = UDim.new(0, 8)
        iconCorner.Parent = icon
        
        local iconText = Instance.new("TextLabel")
        iconText.Size = UDim2.new(1, 0, 1, 0)
        iconText.BackgroundTransparency = 1
        iconText.Text = (info.type == "FAKE") and "🟣" or (info.source == "Hand" and "✋" or "🎒")
        iconText.TextColor3 = Color3.fromRGB(255, 255, 255)
        iconText.TextSize = 20
        iconText.Font = Enum.Font.GothamBold
        iconText.Parent = icon
        
        -- Item name
        local nameLabel = Instance.new("TextLabel")
        nameLabel.Size = UDim2.new(1, -50, 1, 0)
        nameLabel.Position = UDim2.new(0, 48, 0, 0)
        nameLabel.BackgroundTransparency = 1
        nameLabel.Text = info.name .. (info.type == "FAKE" and " [CLONE]" or "")
        nameLabel.TextColor3 = (info.type == "FAKE") and Color3.fromRGB(200, 150, 255) or Color3.fromRGB(220, 220, 255)
        nameLabel.TextSize = 14
        nameLabel.Font = Enum.Font.GothamSemibold
        nameLabel.TextXAlignment = Enum.TextXAlignment.Left
        nameLabel.Parent = btn
        
        -- Source badge
        local badge = Instance.new("TextLabel")
        badge.Size = UDim2.new(0, 70, 0, 18)
        badge.Position = UDim2.new(1, -80, 0.5, -9)
        badge.BackgroundColor3 = (info.type == "FAKE") and Color3.fromRGB(120, 30, 180) or Color3.fromRGB(0, 120, 100)
        badge.BackgroundTransparency = 0.4
        badge.Text = info.source
        badge.TextColor3 = Color3.fromRGB(255, 255, 255)
        badge.TextSize = 10
        badge.Font = Enum.Font.GothamBold
        badge.Parent = btn
        local badgeCorner = Instance.new("UICorner")
        badgeCorner.CornerRadius = UDim.new(1, 0)
        badgeCorner.Parent = badge
        
        -- Store metadata
        btn.Metadata = info
        
        -- Hover effects
        btn.MouseEnter:Connect(function()
            if selectedButton ~= btn then
                TweenService:Create(btn, TweenInfo.new(0.1), {BackgroundColor3 = (info.type == "FAKE") and Color3.fromRGB(45, 30, 70) or Color3.fromRGB(35, 38, 55)}):Play()
            end
        end)
        btn.MouseLeave:Connect(function()
            if selectedButton ~= btn then
                TweenService:Create(btn, TweenInfo.new(0.1), {BackgroundColor3 = (info.type == "FAKE") and Color3.fromRGB(30, 20, 50) or Color3.fromRGB(20, 22, 35)}):Play()
            end
        end)
        
        -- Select only real items
        if info.type == "REAL" then
            btn.MouseButton1Click:Connect(function()
                if selectedButton then
                    TweenService:Create(selectedButton, TweenInfo.new(0.15), {BackgroundColor3 = (selectedButton.Metadata.type == "FAKE") and Color3.fromRGB(30, 20, 50) or Color3.fromRGB(20, 22, 35)}):Play()
                end
                selectedButton = btn
                selectedRealItemName = info.name
                TweenService:Create(btn, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(70, 40, 120)}):Play()
                StatusLabel.Text = "✅ Selected: " .. info.name .. " [" .. info.source .. "]"
                StatusLabel.TextColor3 = Color3.fromRGB(0, 255, 150)
                playWhoosh()
            end)
        else
            -- Fake items - right click to delete
            btn.MouseButton2Click:Connect(function()
                -- Remove fake item
                for i, fake in ipairs(fakeItems) do
                    if fake.name == info.name then
                        table.remove(fakeItems, i)
                        break
                    end
                end
                refreshInventory()
                CounterLabel.Text = "Fake: " .. #fakeItems
                StatusLabel.Text = "🗑️ Removed fake item"
                StatusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
                wait(1.5)
                StatusLabel.Text = "Select a real item"
                StatusLabel.TextColor3 = Color3.fromRGB(150, 150, 200)
                playGlitch()
            end)
        end
        
        itemButtons[btn] = btn
        canvasHeight = canvasHeight + 62
    end
    
    ItemsContainer.CanvasSize = UDim2.new(0, 0, 0, math.max(canvasHeight, 400))
    CounterLabel.Text = "Fake: " .. #fakeItems
    
    if #items == 0 then
        local empty = Instance.new("TextLabel")
        empty.Size = UDim2.new(1, 0, 0, 80)
        empty.BackgroundTransparency = 1
        empty.Text = "💀 No items.\nGet some tools first."
        empty.TextColor3 = Color3.fromRGB(100, 100, 140)
        empty.TextSize = 14
        empty.Font = Enum.Font.Gotham
        empty.TextWrapped = true
        empty.Parent = ItemsContainer
        ItemsContainer.CanvasSize = UDim2.new(0, 0, 0, 100)
    end
end

