local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local Backpack = LocalPlayer:WaitForChild("Backpack")

-- Создание GUI
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Parent = LocalPlayer:WaitForChild("PlayerGui")

local MainFrame = Instance.new("Frame")
MainFrame.Size = UDim2.new(0, 300, 0, 400)
MainFrame.Position = UDim2.new(0.5, -150, 0.5, -200)
MainFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 30)
MainFrame.BackgroundTransparency = 0.1
MainFrame.BorderSizePixel = 2
MainFrame.BorderColor3 = Color3.fromRGB(255, 0, 100)
MainFrame.Parent = ScreenGui

local Title = Instance.new("TextLabel")
Title.Size = UDim2.new(1, 0, 0, 40)
Title.BackgroundColor3 = Color3.fromRGB(255, 0, 100)
Title.Text = "DUPE SYSTEM [BETA]"
Title.TextColor3 = Color3.fromRGB(255, 255, 255)
Title.Font = Enum.Font.GothamBold
Title.TextSize = 18
Title.Parent = MainFrame

local DupeButton = Instance.new("TextButton")
DupeButton.Size = UDim2.new(0.8, 0, 0, 50)
DupeButton.Position = UDim2.new(0.1, 0, 0.5, -25)
DupeButton.BackgroundColor3 = Color3.fromRGB(255, 0, 100)
DupeButton.Text = "ДЮПНУТЬ ВСЕ"
DupeButton.TextColor3 = Color3.fromRGB(255, 255, 255)
DupeButton.Font = Enum.Font.GothamBold
DupeButton.TextSize = 16
DupeButton.Parent = MainFrame

local StatusLabel = Instance.new("TextLabel")
StatusLabel.Size = UDim2.new(1, 0, 0, 30)
StatusLabel.Position = UDim2.new(0, 0, 1, -30)
StatusLabel.BackgroundTransparency = 1
StatusLabel.Text = "Готов к работе..."
StatusLabel.TextColor3 = Color3.fromRGB(150, 150, 150)
StatusLabel.Font = Enum.Font.Gotham
StatusLabel.TextSize = 12
StatusLabel.Parent = MainFrame

-- Анимация при наведении
DupeButton.MouseEnter:Connect(function()
    DupeButton.BackgroundColor3 = Color3.fromRGB(200, 0, 80)
end)

DupeButton.MouseLeave:Connect(function()
    DupeButton.BackgroundColor3 = Color3.fromRGB(255, 0, 100)
end)

-- ТЕОРЕТИЧЕСКИЙ метод дюпа (не работает в актуальном Roblox)
DupeButton.MouseButton1Click:Connect(function()
    StatusLabel.Text = "Попытка дюпа..."
    StatusLabel.TextColor3 = Color3.fromRGB(255, 200, 0)
    
    -- Имитация процесса (в реальности Roblox отвергнет любые клиентские модификации инвентаря)
    local success = false
    local items = Backpack:GetChildren()
    
    for _, item in pairs(items) do
        if item:IsA("Tool") then
            -- Этот метод уже не работает из-за серверной проверки RemoteEvents
            pcall(function()
                -- Фейковый дюп для демонстрации интерфейса
                success = true
            end)
        end
    end
    
    wait(0.5)
    
    if success then
        StatusLabel.Text = "Дюп выполнен! (демо-режим)"
        StatusLabel.TextColor3 = Color3.fromRGB(0, 255, 0)
    else
        StatusLabel.Text = "Ошибка: метод неактуален"
        StatusLabel.TextColor3 = Color3.fromRGB(255, 0, 0)
    end
    
    wait(2)
    StatusLabel.Text = "Готов к работе..."
    StatusLabel.TextColor3 = Color3.fromRGB(150, 150, 150)
end)

-- Возможные проблемы системы отмечены
-- Реальный дюп в Roblox 2024+ невозможен из-за:
-- 1. Серверной авторизации всех действий с инвентарем
-- 2. Проверки RemoteEvents
