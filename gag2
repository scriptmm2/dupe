StatusLabel.Parent = MainFrame

-- Переменная для выбранного предмета
local selectedItem = nil
local itemButtons = {}

-- Функция обновления списка предметов
local function UpdateItemList()
    -- Очистка списка
    for _, btn in pairs(itemButtons) do
        btn:Destroy()
    end
    itemButtons = {}
    
    -- Получение предметов из рюкзака
    local items = Backpack:GetChildren()
    local canvasHeight = 0
    
    for _, item in pairs(items) do
        if item:IsA("Tool") then
            local itemButton = Instance.new("TextButton")
            itemButton.Size = UDim2.new(1, -10, 0, 45)
            itemButton.BackgroundColor3 = Color3.fromRGB(40, 40, 50)
            itemButton.BorderSizePixel = 1
            itemButton.BorderColor3 = Color3.fromRGB(80, 80, 100)
            itemButton.Text = item.Name .. " [" .. (item:FindFirstChild("Handle") and "Tool" or "Item") .. "]"
            itemButton.TextColor3 = Color3.fromRGB(220, 220, 220)
            itemButton.Font = Enum.Font.Gotham
            itemButton.TextSize = 14
            itemButton.Parent = ItemListFrame
            
            -- Выделение при наведении
            itemButton.MouseEnter:Connect(function()
                if selectedItem ~= itemButton then
                    itemButton.BackgroundColor3 = Color3.fromRGB(60, 60, 80)
                end
            end)
            itemButton.MouseLeave:Connect(function()
                if selectedItem ~= itemButton then
                    itemButton.BackgroundColor3 = Color3.fromRGB(40, 40, 50)
                end
            end)
            
            -- Выбор предмета
            itemButton.MouseButton1Click:Connect(function()
                -- Сброс выделения всех кнопок
                for _, btn in pairs(itemButtons) do
                    btn.BackgroundColor3 = Color3.fromRGB(40, 40, 50)
                end
                -- Выделение выбранной
                itemButton.BackgroundColor3 = Color3.fromRGB(0, 150, 100)
                selectedItem = itemButton
                StatusLabel.Text = "Выбран: " .. item.Name
                StatusLabel.TextColor3 = Color3.fromRGB(0, 255, 150)
            end)
            
            itemButtons[item.Name] = itemButton
            canvasHeight = canvasHeight + 50
        end
    end
    
    ItemListFrame.CanvasSize = UDim2.new(0, 0, 0, canvasHeight)
    
    if canvasHeight == 0 then
        local emptyLabel = Instance.new("TextLabel")
        emptyLabel.Size = UDim2.new(1, 0, 0, 100)
        emptyLabel.BackgroundTransparency = 1
        emptyLabel.Text = "Нет предметов в рюкзаке"
        emptyLabel.TextColor3 = Color3.fromRGB(150, 150, 150)
        emptyLabel.Font = Enum.Font.Gotham
        emptyLabel.TextSize = 14
        emptyLabel.Parent = ItemListFrame
        ItemListFrame.CanvasSize = UDim2.new(0, 0, 0, 100)
    end
end

-- Перетаскивание GUI
TitleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = MainFrame.Position
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
    end
end)

-- Закрытие GUI
CloseButton.MouseButton1Click:Connect(function()
    ScreenGui:Destroy()
end)

-- Анимация кнопки
DupeButton.MouseEnter:Connect(function()
    DupeButton.BackgroundColor3 = Color3.fromRGB(200, 0, 80)
end)

DupeButton.MouseLeave:Connect(function()
    DupeButton.BackgroundColor3 = Color3.fromRGB(255, 0, 100)
end)

-- ВИЗУАЛЬНЫЙ ДЮП (НЕ РЕАЛЬНЫЙ)
DupeButton.MouseButton1Click:Connect(function()
    if not selectedItem then
        StatusLabel.Text = "Сначала выберите предмет!"
        StatusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
        wait(1.5)
        StatusLabel.Text = "Выберите предмет"
        StatusLabel.TextColor3 = Color3.fromRGB(150, 150, 150)
        return
    end
    
    -- Находим реальный предмет по имени
    local realItem = nil
    for _, item in pairs(Backpack:GetChildren()) do
        if item:IsA("Tool") and item.Name == selectedItem.Text:match("(.*) %[") then
            realItem = item
            break
        end
    end
    
    if not realItem then
        StatusLabel.Text = "Предмет не найден!"
        return
    end
    
    StatusLabel.Text = "Дюпаю: " .. realItem.Name .. "..."
    StatusLabel.TextColor3 = Color3.fromRGB(255, 200, 0)
    
    -- Визуальный эффект
    DupeButton.BackgroundColor3 = Color3.fromRGB(100, 0, 200)
    wait(0.3)
    
    -- ВИЗУАЛЬНОЕ ДОБАВЛЕНИЕ КОПИИ (ТОЛЬКО ГРАФИКА)
    -- Создаем визуальный элемент поверх рюкзака (не настоящий предмет)
    local fakeItemFrame = Instance.new("Frame")
    fakeItemFrame.Size = UDim2.new(0, 280, 0, 40)
    fakeItemFrame.Position = UDim2.new(0.5, -140, 0.2, 0)
    fakeItemFrame.BackgroundColor3 = Color3.fromRGB(0, 255, 100)
    fakeItemFrame.BackgroundTransparency = 0.3
    fakeItemFrame.BorderSizePixel = 2
    fakeItemFrame.BorderColor3 = Color3.fromRGB(0, 255, 0)
    fakeItemFrame.Parent = MainFrame
    
    local fakeText = Instance.new("TextLabel")
    fakeText.Size = UDim2.new(1, 0, 1, 0)
    fakeText.BackgroundTransparency = 1
    fakeText.Text = "+ " .. realItem.Name .. " (ВИЗУАЛЬНАЯ КОПИЯ)"
    fakeText.TextColor3 = Color3.fromRGB(0, 255, 100)
    fakeText.Font = Enum.Font.GothamBold
    fakeText.TextSize = 12
    fakeText.Parent = fakeItemFrame
    
    -- Анимация исчезновения
    for i = 1, 20 do
        wait(0.05)
        fakeItemFrame.Position = UDim2.new(0.5, -140, 0.2, i * 3)
        fakeItemFrame.BackgroundTransparency = 0.3 + (i / 20) * 0.7
        fakeText.TextTransparency = (i / 20)
    end
    
    fakeItemFrame:Destroy()
    
    StatusLabel.Text = "Дюп выполнен! +1 " .. realItem.Name .. " (визуально)"
    StatusLabel.TextColor3 = Color3.fromRGB(0, 255, 0)
    DupeButton.BackgroundColor3 = Color3.fromRGB(255, 0, 100)
    
    wait(2)
    StatusLabel.Text = "Выберите предмет"
    StatusLabel.TextColor3 = Color3.fromRGB(150, 150, 150)
end)

-- Обновление списка при изменении рюкзака
Backpack.ChildAdded:Connect(UpdateItemList)
Backpack.ChildRemoved:Connect(UpdateItemList)

-- Первоначальное заполнение списка
UpdateItemList()

-- Визуальный эффект появления GUI
MainFrame.BackgroundTransparency = 1
for i = 1, 10 do
    wait(0.02)
    MainFrame.BackgroundTransparency = 0.05 * (1 - (i-1)/10)
end
MainFrame.BackgroundTransparency = 0.05
