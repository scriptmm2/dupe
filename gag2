-- Dragging
local dragConn = nil
local dragEndConn = nil

TitleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStartPos = MainFrame.Position
        dragStartMouse = input.Position
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStartMouse
        MainFrame.Position = UDim2.new(dragStartPos.X.Scale, dragStartPos.X.Offset + delta.X, dragStartPos.Y.Scale, dragStartPos.Y.Offset + delta.Y)
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
    end
end)

-- Resizing
ResizeHandle.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        resizing = true
        resizeStartSize = MainFrame.Size
        resizeStartMouse = input.Position
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if resizing and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - resizeStartMouse
        local newWidth = math.clamp(resizeStartSize.X.Offset + delta.X, 350, 800)
        local newHeight = math.clamp(resizeStartSize.Y.Offset + delta.Y, 450, 900)
        MainFrame.Size = UDim2.new(0, newWidth, 0, newHeight)
        -- Adjust inner components proportionally
        ItemsContainer.Size = UDim2.new(1, -30, 0, newHeight - 180)
        BottomPanel.Position = UDim2.new(0, 15, 1, -95)
        BottomPanel.Size = UDim2.new(1, -30, 0, 80)
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        resizing = false
    end
end)

