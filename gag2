-- ██ АВТО-СБОР + ПРОДАЖА (ОДНА ЛУПА)
spawn(function()
    while wait(0.2) do
        if AutoSell or AutoHarvest then
            local rs = game:GetService("ReplicatedStorage")
            local harvestEvent = rs:FindFirstChild("HarvestPlant")
            local sellEvent = rs:FindFirstChild("SellItem")
            
            for _, plot in pairs(workspace:FindFirstChild("Plots") or {}) do
                if AutoHarvest and plot:GetAttribute("IsReady") and harvestEvent then
                    harvestEvent:FireServer(plot)
                end
                if AutoSell and plot:GetAttribute("HasFruit") == false and plot:FindFirstChild("Fruit") then
                    local fruit = plot.Fruit
                    if fruit and sellEvent then
                        sellEvent:FireServer(fruit)
                    end
                end
            end
            
            -- СБОР ИЗ БЭКПЭКА
            if AutoSell then
                for _, tool in pairs(game.Players.LocalPlayer.Backpack:GetChildren()) do
                    if tool:IsA("Tool") and sellEvent then
                        sellEvent:FireServer(tool)
                        wait(0.05)
                    end
                end
            end
        end
    end
end)

