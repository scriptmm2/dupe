-- LocalScript: Rayfield-style menu — local-only inventory copy
-- Places a clone of your equipped tool into YOUR Backpack (client-side only).
-- Server never sees it. Not a real item: can't be used/traded/sold, gone on rejoin.

local Players = game:GetService("Players")
local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")
local backpack = player:WaitForChild("Backpack")

-- ========================= UI =========================
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "DuplicatorGui"
screenGui.ResetOnSpawn = false
screenGui.IgnoreGuiInset = true
screenGui.Parent = playerGui

local main = Instance.new("Frame")
main.Size = UDim2.new(0, 300, 0, 200)
main.Position = UDim2.new(0.5, -150, 0.5, -100)
main.BackgroundColor3 = Color3.fromRGB(24, 24, 28)
main.BorderSizePixel = 0
main.Active = true
main.Draggable = true
main.Parent = screenGui

local mc = Instance.new("UICorner"); mc.CornerRadius = UDim.new(0, 10); mc.Parent = main
local st = Instance.new("UIStroke"); st.Color = Color3.fromRGB(45,45,52); st.Thickness = 1; st.Parent = main

local titleBar = Instance.new("Frame")
titleBar.Size = UDim2.new(1, 0, 0, 38)
titleBar.BackgroundColor3 = Color3.fromRGB(20, 20, 24)
titleBar.BorderSizePixel = 0
titleBar.Parent = main
local tbc = Instance.new("UICorner"); tbc.CornerRadius = UDim.new(0, 10); tbc.Parent = titleBar

local title = Instance.new("TextLabel")
title.Size = UDim2.new(1, -20, 1, 0); title.Position = UDim2.new(0, 14, 0, 0)
title.BackgroundTransparency = 1; title.Font = Enum.Font.GothamBold
title.Text = "Item Duplicator"; title.TextColor3 = Color3.fromRGB(235,235,240)
title.TextSize = 15; title.TextXAlignment = Enum.TextXAlignment.Left
title.Parent = titleBar

local status = Instance.new("TextLabel")
status.Size = UDim2.new(1, -28, 0, 36); status.Position = UDim2.new(0, 14, 0, 50)
status.BackgroundTransparency = 1; status.Font = Enum.Font.Gotham
status.Text = "Equip an item, then press Duplicate.\n(Local only — visible to you)"
status.TextColor3 = Color3.fromRGB(150,150,158); status.TextSize = 12
status.TextXAlignment = Enum.TextXAlignment.Left; status.TextYAlignment = Enum.TextYAlignment.Top
status.Parent = main

local dupBtn = Instance.new("TextButton")
dupBtn.Size = UDim2.new(1, -28, 0, 36); dupBtn.Position = UDim2.new(0, 14, 0, 104)
dupBtn.BackgroundColor3 = Color3.fromRGB(56,110,220); dupBtn.Font = Enum.Font.GothamBold
dupBtn.Text = "Duplicate"; dupBtn.TextColor3 = Color3.fromRGB(255,255,255); dupBtn.TextSize = 14
dupBtn.Parent = main
local dbc = Instance.new("UICorner"); dbc.CornerRadius = UDim.new(0, 6); dbc.Parent = dupBtn

local clearBtn = Instance.new("TextButton")
clearBtn.Size = UDim2.new(1, -28, 0, 32); clearBtn.Position = UDim2.new(0, 14, 0, 148)
clearBtn.BackgroundColor3 = Color3.fromRGB(40,40,46); clearBtn.Font = Enum.Font.Gotham
clearBtn.Text = "Clear Copies"; clearBtn.TextColor3 = Color3.fromRGB(220,220,225); clearBtn.TextSize = 13
clearBtn.Parent = main
local cbc = Instance.new("UICorner"); cbc.CornerRadius = UDim.new(0, 6); cbc.Parent = clearBtn

-- ========================= Logic =========================
local copies = {}

local function getCurrentTool()
	local char = player.Character
	-- equipped tool first, otherwise first tool in backpack
	if char and char:FindFirstChildOfClass("Tool") then
		return char:FindFirstChildOfClass("Tool")
	end
	return backpack:FindFirstChildOfClass("Tool")
end

local function duplicate()
	local tool = getCurrentTool()
	if not tool then
		status.Text = "No item found to copy."
		return
	end

	local clone = tool:Clone()
	clone.Name = tool.Name .. " (copy)"
	-- Local-only: parent into YOUR backpack. Server is never told.
	clone.Parent = backpack

	table.insert(copies, clone)
	status.Text = "Local copy added: " .. #copies .. "\n(only you can see it)"
end

local function clearCopies()
	for _, c in ipairs(copies) do
		if c and c.Parent then c:Destroy() end
	end
	copies = {}
	status.Text = "Cleared local copies."
end

dupBtn.MouseButton1Click:Connect(duplicate)
clearBtn.MouseButton1Click:Connect(clearCopies)
