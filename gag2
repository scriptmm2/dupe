local function Notify(Title, Text, Duration)
    pcall(function()
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = Title or "🌿 RYZEN",
            Text = Text or "",
            Duration = Duration or 3
        })
    end)
    print(string.format("[RYZEN] %s: %s", Title, Text))
end

local function GetEvent(eventName)
    return RS:FindFirstChild(eventName)
end

local function GetAllPlots()
    local plots = WS:FindFirstChild("Plots")
    if plots then
        local list = {}
        for _, v in pairs(plots:GetChildren()) do
            table.insert(list, v)
        end
        return list
    end
    return {}
end

local function GetAllAuras()
    local auras = WS:FindFirstChild("AuraParts")
    if auras then
        local list = {}
        for _, v in pairs(auras:GetChildren()) do
            if v:IsA("Part") then
                table.insert(list, v)
            end
        end
        return list
    end
    return {}
end

local function GetPlayerChar()
    local char = Player.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        return char
    end
    return nil
end

