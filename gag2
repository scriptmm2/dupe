local function makeToggle(text, yVar, color)
    local btn = Instance.new("TextButton", scroll)
    btn.Size = UDim2.new(0.9, 0, 0, 45)
    btn.BackgroundColor3 = color or Color3.fromRGB(50, 50, 70)
    btn.Text = text .. " ❌"
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.TextScaled = true
    btn.Font = Enum.Font.Gotham
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)
    
    local active = false
    btn.MouseButton1Click:Connect(function()
        active = not active
        _G[getfenv().yVar or yVar] = active
        btn.Text = text .. (active and " ✅" or " ❌")
        btn.BackgroundColor3 = active and Color3.fromRGB(70, 180, 70) or Color3.fromRGB(50, 50, 70)
    end)
    return btn
end

local function makeSlider(text, min, max, def, varName)
    local frame = Instance.new("Frame", scroll)
    frame.Size = UDim2.new(0.9, 0, 0, 70)
    frame.BackgroundColor3 = Color3.fromRGB(40, 40, 55)
    Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 8)
    
    local label = Instance.new("TextLabel", frame)
    label.Size = UDim2.new(1, 0, 0, 25)
    label.BackgroundTransparency = 1
    label.Text = text .. ": " .. def
    label.TextColor3 = Color3.fromRGB(255, 255, 255)
    label.TextScaled = true
    
    local slider = Instance.new("TextBox", frame)
    slider.Size = UDim2.new(1, -20, 0, 35)
    slider.Position = UDim2.new(0, 10, 0, 30)
    slider.BackgroundColor3 = Color3.fromRGB(60, 60, 85)
    slider.Text = tostring(def)
    slider.TextColor3 = Color3.fromRGB(255, 255, 255)
    slider.PlaceholderText = tostring(def)
    Instance.new("UICorner", slider).CornerRadius = UDim.new(0, 6)
    
    slider.FocusLost:Connect(function()
        local num = tonumber(slider.Text)
        if num then
            local clamped = math.clamp(num, min, max)
            slider.Text = tostring(clamped)
            label.Text = text .. ": " .. clamped
            _G[varName] = clamped
        else
            slider.Text = tostring(_G[varName] or def)
        end
    end)
end)

